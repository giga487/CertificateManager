    private IEnumerable<OidOption> FilteredOidOptions => OidOptions.Where(MatchesOidFilter);

    private bool MatchesOidFilter(OidOption option)
    {
        var filter = OidFilter?.Trim();
        if(string.IsNullOrEmpty(filter) || filter == "*")
        {
            return true;
        }

        var values = new[] { option.Name, option.Oid, option.Description, option.Category };
        if(!filter.Contains('*'))
        {
            return values.Any(value => value.Contains(filter, StringComparison.OrdinalIgnoreCase));
        }

        var pattern = "^" + Regex.Escape(filter).Replace("\\*", ".*") + "$";
        return values.Any(value => Regex.IsMatch(value, pattern, RegexOptions.IgnoreCase));
    }

