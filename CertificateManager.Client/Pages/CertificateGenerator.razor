    private string[] GetSelectedKeyUsages()
    {
        var selectedKeyUsages = new List<string>();

        if(KeyUsageDigitalSignature) selectedKeyUsages.Add("DigitalSignature");
        if(KeyUsageNonRepudiation) selectedKeyUsages.Add("NonRepudiation");
        if(KeyUsageKeyEncipherment) selectedKeyUsages.Add("KeyEncipherment");
        if(KeyUsageDataEncipherment) selectedKeyUsages.Add("DataEncipherment");
        if(KeyUsageKeyAgreement) selectedKeyUsages.Add("KeyAgreement");

        return selectedKeyUsages.Count > 0 ? selectedKeyUsages.ToArray() : ["DigitalSignature"];
    }

    private static CertificatePrivateKeyAlgorithm ParseKeyAlgorithm(string? keyAlgorithm)
    {
        return Enum.TryParse<CertificatePrivateKeyAlgorithm>(keyAlgorithm, ignoreCase: true, out var parsed)
            ? parsed
            : CertificatePrivateKeyAlgorithm.Rsa2048;
    }

    private static string FormatKeyAlgorithm(string? keyAlgorithm)
    {
        return keyAlgorithm switch
        {
            nameof(CertificatePrivateKeyAlgorithm.Rsa2048) => "RSA 2048",
            nameof(CertificatePrivateKeyAlgorithm.Rsa3072) => "RSA 3072",
            nameof(CertificatePrivateKeyAlgorithm.Rsa4096) => "RSA 4096",
            nameof(CertificatePrivateKeyAlgorithm.EcdsaP256) => "ECDSA P-256",
            nameof(CertificatePrivateKeyAlgorithm.EcdsaP384) => "ECDSA P-384",
            _ => keyAlgorithm ?? string.Empty
        };
    }

    private void SetKeyUsageCheckboxes(string[]? keyUsages)
    {
        KeyUsageDigitalSignature = false;
        KeyUsageNonRepudiation = false;
        KeyUsageKeyEncipherment = false;
        KeyUsageDataEncipherment = false;
        KeyUsageKeyAgreement = false;

        foreach(var keyUsage in keyUsages ?? ["DigitalSignature"])
        {
            if(string.Equals(keyUsage, "DigitalSignature", StringComparison.OrdinalIgnoreCase)) KeyUsageDigitalSignature = true;
            else if(string.Equals(keyUsage, "NonRepudiation", StringComparison.OrdinalIgnoreCase)) KeyUsageNonRepudiation = true;
            else if(string.Equals(keyUsage, "KeyEncipherment", StringComparison.OrdinalIgnoreCase)) KeyUsageKeyEncipherment = true;
            else if(string.Equals(keyUsage, "DataEncipherment", StringComparison.OrdinalIgnoreCase)) KeyUsageDataEncipherment = true;
            else if(string.Equals(keyUsage, "KeyAgreement", StringComparison.OrdinalIgnoreCase)) KeyUsageKeyAgreement = true;
        }
    }

