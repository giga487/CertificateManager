    protected async override Task OnInitializedAsync()
    {
        // await JSRuntime.InvokeVoidAsync("mostraAlert", "Ciao da Blazor C#!");
        DNSStrings  = new List<string>() { "" };
        IPStrings  = new List<string>() { "" };

        if(ID != -1)
        {
            DNSStrings.Clear();
            var cert = await ViewModel.GetCertificateID(ID);
            if(cert is null)
            {
                return;
            }

            Solution = cert.Solution ?? "";
            Name = cert.Name ?? "";
            Password = cert.Password ?? "";
            CommonName = cert.CN ?? "";
            Company = cert.Company ?? "";
            ApplicationUri = cert.ApplicationUri ?? "";
            OrganizationalUnit = cert.OrganizationalUnit ?? "";
            Locality = cert.Locality ?? "Pisa";
            State = cert.State ?? "PI";
            Country = cert.Country ?? "IT";
            ValidFrom = (cert.ValidFromUtc ?? DateTimeOffset.UtcNow).UtcDateTime.Date;
            ValidTo = (cert.ValidToUtc ?? DateTimeOffset.UtcNow.AddYears(10)).UtcDateTime.Date;
            KeyAlgorithm = ParseKeyAlgorithm(cert.KeyAlgorithm);

            // Set OID checkboxes from certificate
            SetOidCheckboxes(cert.Oid);
            SetKeyUsageCheckboxes(cert.KeyUsages);

            foreach(var dns in cert.DNS ?? [])
            {
                if(string.IsNullOrEmpty(dns))
                    continue;

                DNSStrings.Add(dns);
            }

            foreach(var ip in cert.IpAddresses ?? [])
            {
                if(string.IsNullOrEmpty(ip))
                    continue;

                IPStrings.Add(ip);
            }

        }

        await base.OnInitializedAsync();
        StateHasChanged();
    }

    public async void MakeCrt()
    {
        var oid = GetSelectedOids();
        if(ValidFrom is null || ValidTo is null)
        {
            await JSRuntime.InvokeVoidAsync("showAlert", "Certificate validity dates are not valid");
            return;
        }

        var validFromUtc = new DateTimeOffset(DateTime.SpecifyKind(ValidFrom.Value.Date, DateTimeKind.Utc));
        var validToUtc = new DateTimeOffset(DateTime.SpecifyKind(ValidTo.Value.Date, DateTimeKind.Utc));

        var request = new CertificateGenerationRequest
        {
            Solution = Solution,
            Name = Name,
            CommonName = CommonName,
            Organization = Company,
            OrganizationalUnit = OrganizationalUnit,
            Locality = Locality,
            State = State,
            Country = Country,
            PfxPassword = Password,
            ApplicationUri = ApplicationUri,
            DnsNames = DNSStrings.Where(x => !string.IsNullOrWhiteSpace(x)).ToArray(),
            IpAddresses = IPStrings.Where(x => !string.IsNullOrWhiteSpace(x)).ToArray(),
            KeyUsages = GetSelectedKeyUsages(),
            EnhancedKeyUsages = oid.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries),
            ValidFromUtc = validFromUtc,
            ValidToUtc = validToUtc,
            KeyAlgorithm = this.KeyAlgorithm,
            SignatureHashAlgorithm = "SHA384",
            ExportPrivateKeyPem = true
        };

        var result = await ViewModel.Make(request);

        foreach(var res in result ?? new ())
        {
            MakeOutput += $"<br>Created: {res.Created}, Algorithm: {FormatKeyAlgorithm(res.KeyAlgorithm ?? this.KeyAlgorithm.ToString())}, Application URI: {res.ApplicationUri ?? ApplicationUri}, ThumbPrint: {res.ThumbPrint}, Serial: {res.SerialNumber}<br>";
        }

        if(result is null)
        {
            await JSRuntime.InvokeVoidAsync("showAlert", "Certificate is not created");
            ViewModel.OnStateChange("Update the output");
            return;
        }


        Created = true;
        IDString = $"Created the {ViewModel.CreatedCRTId} crt";
        ViewModel.OnStateChange("Update the output");

    }

