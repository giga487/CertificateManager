@page "/certificateGenerator/ID={ID:int}"
@using System.Text.RegularExpressions
@using CertificateManager.src
@using CertificateManager.Client.src.Models
@inject IJSRuntime JSRuntime

@inherits Page<CreateForCertificateMV>

<PageTitle>Create Certificate</PageTitle>

<FluentStack Spacing="10" Orientation="Orientation.Vertical">
    <FluentStack xs="12">
        <h2>Manual Creation</h2>
    </FluentStack>

    <FluentStack HorizontalGap="10" HorizontalAlignment="HorizontalAlignment.Stretch">
        <FluentTextArea Rows="1" @bind-Value=Solution>Solution</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=Name>Name (optional)</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=CommonName>Common Name</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=Company>Organization</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=Password>Password</FluentTextArea>
    </FluentStack>

    <FluentStack HorizontalGap="10" HorizontalAlignment="HorizontalAlignment.Stretch">
        <FluentTextArea Rows="1" @bind-Value=ApplicationUri>Application URI</FluentTextArea>
    </FluentStack>

    <FluentStack HorizontalGap="10" HorizontalAlignment="HorizontalAlignment.Stretch">
        <FluentTextArea Rows="1" @bind-Value=OrganizationalUnit>Organizational Unit</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=Locality>Locality</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=State>State</FluentTextArea>
        <FluentTextArea Rows="1" @bind-Value=Country>Country</FluentTextArea>
    </FluentStack>

    <FluentStack HorizontalGap="10" HorizontalAlignment="HorizontalAlignment.Stretch">
        <div class="certificate-date-field">
            <FluentDatePicker Label="Valid From UTC"
                              @bind-Value=ValidFrom />
        </div>
        <div class="certificate-date-field">
            <FluentDatePicker Label="Valid To UTC"
                              @bind-Value=ValidTo />
        </div>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 1rem;">
        <FluentLabel Weight="FontWeight.Bold">Private Key Algorithm</FluentLabel>
        <select class="oid-filter-input" @bind="KeyAlgorithm">
            <option value="@CertificatePrivateKeyAlgorithm.Rsa2048">RSA 2048</option>
            <option value="@CertificatePrivateKeyAlgorithm.Rsa3072">RSA 3072</option>
            <option value="@CertificatePrivateKeyAlgorithm.Rsa4096">RSA 4096</option>
            <option value="@CertificatePrivateKeyAlgorithm.EcdsaP256">ECDSA P-256</option>
            <option value="@CertificatePrivateKeyAlgorithm.EcdsaP384">ECDSA P-384</option>
        </select>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 1rem;">
        <FluentLabel Weight="FontWeight.Bold">Key Usage</FluentLabel>
        <FluentStack Orientation="Orientation.Horizontal" Style="flex-wrap: wrap;">
            <FluentCheckbox @bind-Value=KeyUsageDigitalSignature>Digital Signature</FluentCheckbox>
            <FluentCheckbox @bind-Value=KeyUsageNonRepudiation>Non Repudiation</FluentCheckbox>
            <FluentCheckbox @bind-Value=KeyUsageKeyEncipherment>Key Encipherment</FluentCheckbox>
            <FluentCheckbox @bind-Value=KeyUsageDataEncipherment>Data Encipherment</FluentCheckbox>
            <FluentCheckbox @bind-Value=KeyUsageKeyAgreement>Key Agreement</FluentCheckbox>
        </FluentStack>
    </FluentStack>

    <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 1rem;">
        <FluentLabel Weight="FontWeight.Bold">Certificate Usage (OID Selection) / Utilizzo Certificato (Selezione OID):</FluentLabel>
        <input class="oid-filter-input"
               type="search"
               placeholder="Filter EKU by name, OID, category. Use * as wildcard."
               value="@OidFilter"
               @oninput="OnOidFilterChanged" />

        <div class="oid-option-list">
            @foreach(var option in FilteredOidOptions)
            {
                <label class="oid-option-row">
                    <input type="checkbox"
                           checked="@GetOidSelection(option.Key)"
                           @onchange="args => SetOidSelection(option.Key, args.Value is true)" />
                    <span class="oid-option-text">
                        <span class="oid-option-main">
                            <strong>@option.Name</strong>
                            <code>@option.Oid</code>
                        </span>
                        <span class="oid-option-description">@option.Description</span>
                        <span class="oid-option-category">@option.Category</span>
                    </span>
                </label>
            }
        </div>
    </FluentStack>


    <FluentStack xs="12">
        <FluentButton IconStart="@(new Icons.Regular.Size16.GlobeArrowUp())" OnClick="() => AddDNSText()">AddDNS</FluentButton>
        <FluentButton IconStart="@(new Icons.Regular.Size16.GlobeArrowUp())" OnClick="() => AddIpText()">AddIP</FluentButton>
    </FluentStack>

    <div style="margin-top: 1rem;">
        <div class="wrap-container">
            @for(int i = 0; i < DNSStrings.Count; i++)
            {
                var index = i;

                <FluentStack ItemSpacing="5" Orientation="Orientation.Horizontal" class="flex-item">
                    <FluentTextArea style="width: 300px;"
                                    Placeholder="@($"DNS {index + 1}")"
                                    @bind-Value="DNSStrings[index]" />

                    <FluentButton IconEnd="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => Remove(index))" />
                </FluentStack>
            }
        </div>
    </div>

    <div style="margin-top: 1rem;">
        <div class="wrap-container">
            @for(int i = 0; i < IPStrings.Count; i++)
            {
                var index = i;

                <FluentStack ItemSpacing="5" Orientation="Orientation.Horizontal" class="flex-item">
                    <FluentTextArea style="width: 300px;"
                                    Placeholder="@($"IP {index + 1}")"
                                    @bind-Value="IPStrings[index]" />

                    <FluentButton IconEnd="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => RemoveIp(index))" />
                </FluentStack>
            }
        </div>
    </div>

        <FluentStack xs="12">
        <FluentButton IconStart="@(new Icons.Regular.Size16.GlobeArrowUp())" OnClick="() => MakeCrt()">Make</FluentButton>
    </FluentStack>


    <FluentGrid>
        @if(Created)
        {
            <FluentStack xs="12"><FluentLabel>@IDString</FluentLabel></FluentStack>

            <FluentStack xs="12">
                <FluentButton Color="Color.Accent" OnClick="(() => ViewModel?.DownloadPFX(ViewModel.CreatedCRTId, Solution))">Download PFX</FluentButton>
                <FluentButton Color="Color.Accent" OnClick="(() => ViewModel?.DownloadCRT(ViewModel.CreatedCRTId, Solution))">Download CRT</FluentButton>
                <FluentButton Color="Color.Accent" OnClick="(() => ViewModel?.DownloadDER(ViewModel.CreatedCRTId, Solution))">Download DER</FluentButton>
            </FluentStack>

            <FluentStack>
                <FluentLabel>Output</FluentLabel>

                <pre class="pre-formatted-text">

                @((MarkupString)MakeOutput)
            </pre>

            </FluentStack>
        }

    </FluentGrid>



</FluentStack>

