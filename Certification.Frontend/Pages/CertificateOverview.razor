@page "/certificate"
@using CertificateManager.Client.src.Models
@using CertificateManager.src
@inject IJSRuntime JSRuntime

@inherits Page<CertificateOvervieVM>

<PageTitle>Certificate Generator</PageTitle>

<div class="certificate-overview-page">
    <h2>Certificates</h2>

    @if (ViewModel?.IsLoading ?? true)
    {
        <FluentProgressRing />
    }
    else if (ViewModel?.Certificates?.CertificatesDB != null && ViewModel.Certificates.CertificatesDB.Any())
    {
        var certificates = ViewModel.Certificates.CertificatesDB
            .OrderBy(c => c.Solution ?? string.Empty)
            .ThenByDescending(c => c.Creation)
            .ToList();
        var authorityLookup = (ViewModel.CertificateAuthorities ?? [])
            .Where(authority => !string.IsNullOrWhiteSpace(authority.Id))
            .GroupBy(authority => authority.Id!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.OrdinalIgnoreCase);

        EnsureSelection(certificates);

        var solutions = certificates
            .GroupBy(c => GetSolutionName(c))
            .Select(group => new SolutionSummary(group.Key, group.Count(), group.Max(c => c.Creation)))
            .OrderBy(summary => summary.Name)
            .ToList();

        var solutionCertificates = certificates
            .Where(c => GetSolutionName(c) == SelectedSolution)
            .OrderByDescending(c => c.Creation)
            .ThenBy(c => GetCertificateTitle(c))
            .ToList();
        var issuerGroups = solutionCertificates
            .GroupBy(c => GetIssuerGroupKey(c))
            .Select(group => new IssuerCertificateGroup(
                group.Key,
                GetIssuerDisplayName(group.First(), authorityLookup),
                GetIssuerGroupSubtitle(group.First(), authorityLookup),
                group.OrderByDescending(c => c.Creation).ThenBy(c => GetCertificateTitle(c)).ToList()))
            .OrderBy(group => group.Name)
            .ToList();

        var selectedCertificate = solutionCertificates.FirstOrDefault(c => c.Id == SelectedCertificateId)
            ?? solutionCertificates.FirstOrDefault();

        <div class="certificate-workspace">
            <section class="certificate-panel certificate-solution-panel">
                <div class="certificate-panel-header">
                    <span>Solutions</span>
                    <strong>@solutions.Count</strong>
                </div>

                <div class="certificate-solution-list">
                    @foreach (var solution in solutions)
                    {
                        var isSelected = solution.Name == SelectedSolution;

                        <button type="button"
                                class="certificate-solution-item @(isSelected ? "selected" : "")"
                                @onclick="() => SelectSolution(solution.Name, certificates)">
                            <span>@solution.Name</span>
                            <small>@solution.Count certificate@(solution.Count == 1 ? string.Empty : "s")</small>
                        </button>
                    }
                </div>
            </section>

            <section class="certificate-panel certificate-list-panel">
                <div class="certificate-panel-header">
                    <span>@SelectedSolution</span>
                    <FluentButton Appearance="Appearance.Accent" OnClick="() => ViewModel?.Regenerate(-1)">New</FluentButton>
                </div>

                <div class="certificate-list">
                    @foreach (var issuerGroup in issuerGroups)
                    {
                        <div class="certificate-issuer-group">
                            <div class="certificate-issuer-header">
                                <div>
                                    <span>@issuerGroup.Name</span>
                                    <small>@issuerGroup.Subtitle</small>
                                </div>
                                <strong>@issuerGroup.Certificates.Count</strong>
                            </div>

                            @foreach (var certificate in issuerGroup.Certificates)
                            {
                                var isSelected = certificate.Id == selectedCertificate?.Id;

                                <button type="button"
                                        class="certificate-list-item @(isSelected ? "selected" : "")"
                                        @onclick="() => SelectCertificate(certificate)">
                                    <span class="certificate-list-title">@GetCertificateTitle(certificate)</span>
                                    <span class="certificate-list-meta">CN: @Display(certificate.CN)</span>
                                    <span class="certificate-list-meta">DNS: @JoinValues(certificate.DNS)</span>
                                    <span class="certificate-list-footer">
                                        <span>@Display(certificate.KeyAlgorithm)</span>
                                        <span>@certificate.Creation.ToString("yyyy-MM-dd")</span>
                                    </span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="certificate-panel certificate-detail-panel">
                @if (selectedCertificate is null)
                {
                    <p>No certificate selected.</p>
                }
                else
                {
                    <div class="certificate-detail-header">
                        <div>
                            <h3>@GetCertificateTitle(selectedCertificate)</h3>
                            <span>@Display(selectedCertificate.CN)</span>
                        </div>
                        <FluentButton Color="Color.Success" OnClick="(() => ViewModel?.Regenerate(selectedCertificate.Id))">Modify</FluentButton>
                    </div>

                    <div class="certificate-download-panel">
                        <select class="oid-filter-input" @bind="SelectedDownload">
                            <option value="@CertificateDownloadKind.Pfx">PFX</option>
                            <option value="@CertificateDownloadKind.CertificatePem">Certificate CRT/PEM</option>
                            <option value="@CertificateDownloadKind.CertificateDer">Certificate DER</option>
                            <option value="@CertificateDownloadKind.ChainPem">Chain CRT</option>
                            <option value="@CertificateDownloadKind.RootPem">Root CRT</option>
                            <option value="@CertificateDownloadKind.RootDer">Root DER</option>
                            <option value="@CertificateDownloadKind.IntermediatePem">Intermediate CRT</option>
                            <option value="@CertificateDownloadKind.PrivateKeyPem">Private key PEM</option>
                            <option value="@CertificateDownloadKind.RootThumbprint">Root thumbprint</option>
                        </select>

                        @if(SelectedDownload == CertificateDownloadKind.Pfx)
                        {
                            <div class="certificate-download-options">
                                <FluentCheckbox @bind-Value="DownloadPfxWithIntermediates">Include intermediates</FluentCheckbox>
                                <FluentCheckbox @bind-Value="DownloadPfxWithRoot">Include root CA</FluentCheckbox>
                            </div>
                        }
                        else if(SelectedDownload == CertificateDownloadKind.CertificatePem)
                        {
                            <div class="certificate-download-options">
                                <FluentCheckbox @bind-Value="DownloadCertificateWithIntermediates">Include intermediates</FluentCheckbox>
                                <FluentCheckbox @bind-Value="DownloadCertificateWithRoot">Include root CA</FluentCheckbox>
                            </div>
                        }
                        else if(SelectedDownload == CertificateDownloadKind.ChainPem)
                        {
                            <div class="certificate-download-options">
                                <FluentCheckbox @bind-Value="DownloadChainWithLeaf">Server</FluentCheckbox>
                                <FluentCheckbox @bind-Value="DownloadChainWithIntermediates">Intermediates</FluentCheckbox>
                                <FluentCheckbox @bind-Value="DownloadChainWithRoot">Root CA</FluentCheckbox>
                            </div>
                        }

                        <FluentButton Appearance="Appearance.Accent" OnClick="(() => DownloadSelected(selectedCertificate))">Download</FluentButton>
                    </div>

                    <div class="certificate-detail-grid">
                        <span>Solution</span><strong>@Display(selectedCertificate.Solution)</strong>
                        <span>Name</span><strong>@Display(selectedCertificate.Name)</strong>
                        <span>Organization</span><strong>@Display(selectedCertificate.Company)</strong>
                        <span>Application URI</span><strong>@Display(selectedCertificate.ApplicationUri)</strong>
                        <span>Address</span><strong>@Display(selectedCertificate.Address)</strong>
                        <span>DNS</span><strong>@JoinValues(selectedCertificate.DNS)</strong>
                        <span>IP</span><strong>@JoinValues(selectedCertificate.IpAddresses)</strong>
                        <span>Algorithm</span><strong>@Display(selectedCertificate.KeyAlgorithm)</strong>
                        <span>Issuer</span><strong>@GetIssuerDisplayName(selectedCertificate, authorityLookup)</strong>
                        <span>Issuer Thumbprint</span><strong class="certificate-mono">@Display(selectedCertificate.IssuerThumbPrint)</strong>
                        <span>Key Usage</span><strong>@JoinValues(selectedCertificate.KeyUsages)</strong>
                        <span>OID</span><strong>@Display(selectedCertificate.Oid)</strong>
                        <span>Valid From</span><strong>@FormatDate(selectedCertificate.ValidFromUtc)</strong>
                        <span>Valid To</span><strong>@FormatDate(selectedCertificate.ValidToUtc)</strong>
                        <span>Created</span><strong>@selectedCertificate.Creation.ToString("yyyy-MM-dd HH:mm")</strong>
                        <span>Root Thumbprint</span><strong class="certificate-mono">@Display(selectedCertificate.RootThumbPrint)</strong>
                    </div>
                }
            </section>
        </div>
    }
    else
    {
        <p>No certificates found.</p>
    }
</div>

@code {
    string? SelectedSolution { get; set; }
    int? SelectedCertificateId { get; set; }
    CertificateDownloadKind SelectedDownload { get; set; } = CertificateDownloadKind.Pfx;
    bool DownloadPfxWithIntermediates { get; set; } = true;
    bool DownloadPfxWithRoot { get; set; }
    bool DownloadCertificateWithIntermediates { get; set; }
    bool DownloadCertificateWithRoot { get; set; }
    bool DownloadChainWithLeaf { get; set; } = true;
    bool DownloadChainWithIntermediates { get; set; } = true;
    bool DownloadChainWithRoot { get; set; }

    protected async override Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    private void EnsureSelection(IReadOnlyList<Certificate> certificates)
    {
        if(certificates.Count == 0)
        {
            SelectedSolution = null;
            SelectedCertificateId = null;
            return;
        }

        if(string.IsNullOrWhiteSpace(SelectedSolution)
            || !certificates.Any(c => GetSolutionName(c) == SelectedSolution))
        {
            SelectedSolution = GetSolutionName(certificates[0]);
        }

        var selectedCertificate = certificates
            .Where(c => GetSolutionName(c) == SelectedSolution)
            .OrderByDescending(c => c.Creation)
            .FirstOrDefault();

        if(SelectedCertificateId is null
            || !certificates.Any(c => c.Id == SelectedCertificateId && GetSolutionName(c) == SelectedSolution))
        {
            SelectedCertificateId = selectedCertificate?.Id;
        }
    }

    private void SelectSolution(string solution, IReadOnlyList<Certificate> certificates)
    {
        SelectedSolution = solution;
        SelectedCertificateId = certificates
            .Where(c => GetSolutionName(c) == solution)
            .OrderByDescending(c => c.Creation)
            .FirstOrDefault()
            ?.Id;
    }

    private void SelectCertificate(Certificate certificate)
    {
        SelectedSolution = GetSolutionName(certificate);
        SelectedCertificateId = certificate.Id;
    }

    private async Task ShowThumbprint(string? thumbprint)
    {
        var message = string.IsNullOrWhiteSpace(thumbprint)
            ? "Thumbprint not available."
            : thumbprint;

        await JSRuntime.InvokeVoidAsync("showAlert", message);
    }

    private async Task DownloadSelected(Certificate certificate)
    {
        switch(SelectedDownload)
        {
            case CertificateDownloadKind.Pfx:
                ViewModel?.DownloadPFX(certificate.Id, DownloadPfxWithIntermediates, DownloadPfxWithRoot);
                break;
            case CertificateDownloadKind.CertificatePem:
                ViewModel?.DownloadCertificatePEM(certificate.Id, DownloadCertificateWithIntermediates, DownloadCertificateWithRoot);
                break;
            case CertificateDownloadKind.CertificateDer:
                ViewModel?.DownloadDER(certificate.Id);
                break;
            case CertificateDownloadKind.ChainPem:
                ViewModel?.DownloadChainCRT(certificate.Id, DownloadChainWithLeaf, DownloadChainWithIntermediates, DownloadChainWithRoot);
                break;
            case CertificateDownloadKind.RootPem:
                ViewModel?.DownloadRootCRT(certificate.Id);
                break;
            case CertificateDownloadKind.RootDer:
                ViewModel?.DownloadRootDER(certificate.Id);
                break;
            case CertificateDownloadKind.IntermediatePem:
                ViewModel?.DownloadIntermediateCRT(certificate.Id);
                break;
            case CertificateDownloadKind.PrivateKeyPem:
                ViewModel?.DownloadPrivateKeyPEM(certificate.Id);
                break;
            case CertificateDownloadKind.RootThumbprint:
                await ShowThumbprint(certificate.RootThumbPrint);
                break;
        }
    }

    private static string GetSolutionName(Certificate certificate)
    {
        return string.IsNullOrWhiteSpace(certificate.Solution)
            ? "Unassigned"
            : certificate.Solution;
    }

    private static string GetCertificateTitle(Certificate certificate)
    {
        if(!string.IsNullOrWhiteSpace(certificate.Name))
        {
            return certificate.Name;
        }

        if(!string.IsNullOrWhiteSpace(certificate.CN))
        {
            return certificate.CN;
        }

        return $"Certificate {certificate.Id}";
    }

    private static string GetIssuerGroupKey(Certificate certificate)
    {
        if(!string.IsNullOrWhiteSpace(certificate.IssuerAuthorityId))
        {
            return $"authority:{certificate.IssuerAuthorityId.Trim()}";
        }

        if(!string.IsNullOrWhiteSpace(certificate.IssuerThumbPrint))
        {
            return $"thumbprint:{certificate.IssuerThumbPrint.Trim()}";
        }

        return "issuer:unknown";
    }

    private static string GetIssuerDisplayName(Certificate certificate, IReadOnlyDictionary<string, CertificateAuthorityInfo> authorityLookup)
    {
        if(!string.IsNullOrWhiteSpace(certificate.IssuerAuthorityId)
            && authorityLookup.TryGetValue(certificate.IssuerAuthorityId, out var authority))
        {
            return string.IsNullOrWhiteSpace(authority.Name)
                ? Display(authority.Subject)
                : authority.Name;
        }

        if(!string.IsNullOrWhiteSpace(certificate.IssuerAuthorityId))
        {
            return certificate.IssuerAuthorityId;
        }

        if(!string.IsNullOrWhiteSpace(certificate.IssuerThumbPrint))
        {
            return $"Issuer {ShortThumbprint(certificate.IssuerThumbPrint)}";
        }

        return "Issuer not recorded";
    }

    private static string GetIssuerGroupSubtitle(Certificate certificate, IReadOnlyDictionary<string, CertificateAuthorityInfo> authorityLookup)
    {
        if(!string.IsNullOrWhiteSpace(certificate.IssuerAuthorityId)
            && authorityLookup.TryGetValue(certificate.IssuerAuthorityId, out var authority))
        {
            var role = string.IsNullOrWhiteSpace(authority.Role) ? "Issuer" : authority.Role;
            var thumbprint = ShortThumbprint(authority.Thumbprint);
            return string.IsNullOrWhiteSpace(thumbprint) ? role : $"{role} - {thumbprint}";
        }

        if(!string.IsNullOrWhiteSpace(certificate.IssuerThumbPrint))
        {
            return ShortThumbprint(certificate.IssuerThumbPrint);
        }

        return "Legacy certificate";
    }

    private static string ShortThumbprint(string? thumbprint)
    {
        if(string.IsNullOrWhiteSpace(thumbprint))
        {
            return string.Empty;
        }

        var normalized = thumbprint.Replace(" ", string.Empty).Trim();
        return normalized.Length <= 12
            ? normalized
            : $"{normalized[..6]}...{normalized[^6..]}";
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string JoinValues(IEnumerable<string>? values)
    {
        var result = values?
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .ToArray();

        return result is { Length: > 0 } ? string.Join(", ", result) : "-";
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value?.ToString("yyyy-MM-dd") ?? "-";
    }

    private sealed record SolutionSummary(string Name, int Count, DateTime LastCreated);
    private sealed record IssuerCertificateGroup(string Key, string Name, string Subtitle, List<Certificate> Certificates);

    private enum CertificateDownloadKind
    {
        Pfx,
        CertificatePem,
        CertificateDer,
        ChainPem,
        RootPem,
        RootDer,
        IntermediatePem,
        PrivateKeyPem,
        RootThumbprint
    }
}
